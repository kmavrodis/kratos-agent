{
  "name": "epic-fhir-mcp-server",
  "version": "0.1.0",
  "description": "Mock Epic-style EHR (FHIR R4 resources) as a stdio MCP server (patients, encounters, conditions, medications, observations, allergies, procedures).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "epic-fhir-mcp-server": "dist/server.js"
  },
  "files": [
    "dist/",
    "src/data/"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/server.js', 0o755)\" && cp -R src/data dist/data",
    "link": "npm link"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
