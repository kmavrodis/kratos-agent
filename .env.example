# ============================================================================
# .env.example — All environment variables needed to run kratos-agent locally
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================================

# ── Azure Developer CLI ─────────────────────────────────────────────────────
AZURE_ENV_NAME=
AZURE_LOCATION=eastus2
AZURE_SUBSCRIPTION_ID=

# ── Microsoft Foundry (AI model endpoint) ───────────────────────────────────
# e.g. https://<account>.cognitiveservices.azure.com/
FOUNDRY_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o
FOUNDRY_PROJECT_NAME=

# Foundry API key for Copilot SDK BYOK (local dev only)
# In production this is read from Key Vault via Managed Identity at startup
FOUNDRY_API_KEY=

# ── Azure Cosmos DB ─────────────────────────────────────────────────────────
# e.g. https://<account>.documents.azure.com:443/
COSMOS_DB_ENDPOINT=
COSMOS_DB_DATABASE=kratos-agent

# ── Azure AI Search ─────────────────────────────────────────────────────────
# e.g. https://<account>.search.windows.net
AI_SEARCH_ENDPOINT=
AI_SEARCH_INDEX=wm-knowledge-base

# ── Azure Key Vault ─────────────────────────────────────────────────────────
# e.g. https://<vault-name>.vault.azure.net/
KEY_VAULT_URI=

# ── Azure Blob Storage (skills store) ───────────────────────────────────────
# e.g. https://<account>.blob.core.windows.net
BLOB_STORAGE_ENDPOINT=
BLOB_SKILLS_CONTAINER=skills

# ── Observability (Application Insights / OpenTelemetry) ────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=kratos-agent-service

# Set to "true" to capture full prompts/completions in traces (verbose, may contain PII)
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=false
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false

# ── Backend Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# ── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MSAL_CLIENT_ID=
NEXT_PUBLIC_MSAL_AUTHORITY=

# Local Development Only (never commit .env)
# All production secrets are in Key Vault via Managed Identity
