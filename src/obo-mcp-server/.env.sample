# OBO MCP server configuration (sample values — real values come from azd/bicep)

# Tenant that issues + validates user tokens, and that the OBO flow runs in.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# appId (GUID) of the OBO server app registration. Used as:
#  - the OBO client_id, and
#  - the expected inbound token audience (api://<appId> or the bare GUID).
OBO_API_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client id of the user-assigned managed identity bound to this container app.
# Selects which MI mints the federated token-exchange assertion (secret-less OBO).
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Downstream Graph delegated scope(s) requested via OBO (space-separated).
GRAPH_SCOPES=https://graph.microsoft.com/User.Read

# Allow-list of client app ids permitted to call this server (space/comma
# separated). Checked against the token azp/appid claim. Set to the SPA client
# app id (and optionally VS Code's app id) so only approved frontends can act as
# the user. Leave empty to allow any caller that passes audience+scope+tenant.
ALLOWED_CLIENT_APP_IDS=

PORT=8000
LOG_LEVEL=INFO

# LOCAL DEV ONLY — confidential-client secret for the OBO exchange. When set, the
# server uses OnBehalfOfCredential(client_secret=...) instead of the cloud's
# secret-less managed-identity federated assertion (managed identity is
# unavailable off-Azure). Same app registration, same real Entra OBO -> Graph
# hop. NEVER set this in a deployed environment.
OBO_CLIENT_SECRET=

# Deployment environment. Must be a dev value (development/dev/local) for
# AUTH_DISABLED to be honoured; in production the server refuses to start with it.
ENVIRONMENT=production

# LOCAL DEV ONLY — set true to bypass JWT validation while smoke-testing the
# MCP transport without a real Entra token. Only honoured when ENVIRONMENT is a
# dev value; the server refuses to start with this enabled in production.
AUTH_DISABLED=false
