# yaml-language-server: $schema=https://raw.githubusercontent.com/microsoft/AgentSchema/refs/heads/main/schemas/v1.0/AgentManifest.yaml
#
# Foundry Agent manifest for ${name} — exported from Kratos.
#
# The platform-side declaration consumed by the Foundry portal / agent
# catalogue. Mirrors Kratos's own agent.manifest.yaml.

name: ${slug}
displayName: "${name}"
description: >
  ${description}
metadata:
  tags:
    - AI Agent Hosting
    - GitHub Copilot SDK
    - Invocations Protocol
    - Kratos Export
template:
  name: ${slug}
  kind: hosted
  protocols:
    - protocol: invocations
      version: 1.0.0
  environment_variables:
    # APPLICATIONINSIGHTS_CONNECTION_STRING is auto-injected by the platform.
    # FOUNDRY_PROJECT_ENDPOINT is auto-injected by the platform.
    - name: MODEL_DEPLOYMENT_NAME
      value: $${FOUNDRY_MODEL_DEPLOYMENT}
    - name: COSMOS_DB_ENDPOINT
      value: $${AZURE_COSMOS_DB_ENDPOINT}
    - name: AZURE_AI_SEARCH_ENDPOINT
      value: $${AZURE_AI_SEARCH_ENDPOINT}
    - name: KEY_VAULT_URI
      value: $${AZURE_KEY_VAULT_URI}
    - name: BLOB_STORAGE_ENDPOINT
      value: $${AZURE_BLOB_STORAGE_ENDPOINT}
    - name: BLOB_SKILLS_CONTAINER
      value: skills
    - name: COSMOS_DB_DATABASE
      value: kratos-agent-${slug}
parameters:
  properties: []
resources: []
