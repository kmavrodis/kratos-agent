# ── Local Docker Compose stack (frontend/backend/hosted-agent/obo-mcp-server) ──
# Copy to .env and fill in. `docker compose` reads this file automatically.
# These values drive the LOCAL demo; the deployed stack gets its config from azd.

# GitHub Copilot token the LOCAL hosted agent uses to reach api.githubcopilot.com.
COPILOT_GITHUB_TOKEN=

# ── OBO (On-Behalf-Of) local auth ────────────────────────────────────────────
# Real Entra is used locally too; only the OBO server's SELF-auth differs from
# the cloud. In the cloud it is secret-less (managed-identity federated
# credential). Locally there is no managed identity, so it uses a client secret
# on the SAME OBO server app registration. Mint one with:
#   az ad app credential reset --id <OBO_SERVER_APP_CLIENT_ID> --display-name local-dev --years 1
# (requires permission to manage the app reg). Never commit the real value.
OBO_CLIENT_SECRET=

# Public (non-secret) identifiers — defaults in docker-compose.yml already point
# at the deployed demo app registrations; override only for a different tenant.
# AZURE_TENANT_ID=f7d09a0b-c429-41ac-b105-9ce32d6e5358
# OBO_API_CLIENT_ID=bec3169c-c01e-4acc-9974-bd9271f9bfae           # OBO server app
# ALLOWED_CLIENT_APP_IDS=f31799cd-b0a5-4055-b7f9-574c25ea0238      # SPA client app
# GRAPH_SCOPES=https://graph.microsoft.com/User.Read
